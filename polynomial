#include <stdio.h>

int main()
{
    int n, i;
    int x;
    int result = 0;
    int coeff[10];

    printf("Enter degree of polynomial: ");
    scanf("%d", &n);

    printf("Enter coefficients (from highest degree to constant term):\n");
    for(i = 0; i <= n; i++)
    {
        scanf("%d", &coeff[i]);
    }

    printf("Enter value of x: ");
    scanf("%d", &x);

    // Horner's method
    result = coeff[0];
    for(i = 1; i <= n; i++)
    {
        result = result * x + coeff[i];
    }

    printf("Polynomial value = %d\n", result);

    return 0;
}
